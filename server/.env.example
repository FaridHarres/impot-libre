# === Base de données ===
DATABASE_URL=postgresql://user:password@localhost:5432/impot_libre

# === JWT ===
JWT_SECRET=changez-moi-en-production
JWT_EXPIRES_IN=7d

# === Serveur ===
PORT=5000
NODE_ENV=development

# === URLs ===
BASE_URL=https://impot-libre.fr
FRONTEND_URL=https://impot-libre.fr

# === CORS ===
CORS_ORIGIN=http://localhost:3000

# === Brevo (ex-Sendinblue) — Email (vérification + OTP admin) ===
BREVO_API_KEY=xkeysib-votre-cle-api

# === Admin ===
ADMIN_EMAIL=admin@impot-libre.fr

# === URL secrète Admin (32 caractères aléatoires) ===
ADMIN_URL_SECRET=generez-une-chaine-aleatoire-de-32-caracteres
